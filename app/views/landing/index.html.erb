<div class="max-w-3xl mx-auto py-12 px-4">
  <div class="flex flex-col md:flex-row md:items-center md:space-x-8 text-center md:text-left">
    <!-- Profile Image -->
    <img src="<%= asset_path('mel-transp.png') %>" alt="Profile" class="w-32 h-32 rounded-full mb-4 md:mb-0">
    <!-- Text Content (Vertically Centered) -->
    <div class="flex flex-col justify-center">
      <h1 class="text-2xl font-bold mb-2">Welcome!</h1>
      <p class="text-gray-600 mb-4">
        Hi, I'm Melissa. This is my portfolio. Please enter the password to view my projects.
      </p>
    </div>
  </div>
  <!-- Password Form -->
  <div class="mt-8 max-w-sm mx-auto">
    <%= form_with url: authenticate_path, method: :post, local: true do %>
      <div class="mb-4">
        <%= password_field_tag :password, nil, placeholder: "Enter password", class: "border rounded px-4 py-2 w-full" %>
      </div>
      <button type="submit" class="relative block w-full text-center overflow-hidden px-3 py-2 rounded transition whitespace-normal break-words group">
        <span class="relative z-10 transition-colors duration-500 group-hover:text-white">
          Enter
        </span>
        <span class="absolute inset-0 bg-text transform scale-x-0 origin-right transition-transform duration-500 ease-in-out group-hover:scale-x-100 z-0"></span>
      </button>
    <% end %>
  </div>
</div>
