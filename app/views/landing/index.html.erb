<div class="max-w-xl mx-auto text-center py-12">
  <img src="<%= asset_path('mel_transparent.png') %>" alt="Profile" class="w-32 h-32 rounded-full mx-auto mb-4">
  <h1 class="text-2xl font-bold mb-2">Welcome!</h1>
  <p class="text-gray-600 mb-6">Hi, I'm Melissa. This is my portfolio. Please enter the password to view projects.</p>
  <%= form_with url: authenticate_path, method: :post, local: true do %>
    <div class="mb-4">
      <%= password_field_tag :password, nil, placeholder: "Enter password", class: "border rounded px-4 py-2 w-full" %>
    </div>
    <%= submit_tag "Enter", class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
  <% end %>
</div>
