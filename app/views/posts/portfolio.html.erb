<div class="min-h-screen flex flex-col md:flex-row  text-text">
  <!-- Sidebar Navigation -->
  <nav class="w-full md:w-auto md:sticky md:top-0 md:h-screen p-4 flex md:flex-col justify-between">
    <div class="space-y-2">
      <% @posts.each do |post| %>
        <%= link_to portfolio_path(post), class: "relative block text-left overflow-hidden px-3 py-2 rounded transition text-sm font-bold group" do %>
          <span class="relative z-10 transition-colors duration-500 group-hover:text-white">
            <%= post.title %>
          </span>
          <span class="absolute inset-0 bg-text transform scale-x-0 origin-right transition-transform duration-500 ease-in-out group-hover:scale-x-100 z-0"></span>
        <% end %>
      <% end %>
      <% # <%= render partial: 'posts/edit_link' %>
    </div>
    <div class="hidden md:block text-sm mt-6">
      &copy; <%= Date.today.year %> Melissa Basaran
    </div>
  </nav>
  <!-- Post Content -->
  <main class="flex-1 p-4 md:p-6 overflow-y-auto">
    <% if @post %>
      <%= render partial: "posts/post", locals: { post: @post } %>
    <% else %>
      <div class="text-gray-400 text-center mt-20">Select a project to view details.</div>
    <% end %>
  </main>
</div>
