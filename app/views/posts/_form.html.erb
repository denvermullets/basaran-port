<%# === Existing Images + Delete Buttons === %>
<% if post.images.attached? %>
  <div class="mb-6">
    <p class="text-sm font-medium text-gray-700 mb-2">Existing Images</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <% post.images.each do |image| %>
        <div class="relative border rounded-md overflow-hidden">
          <%= image_tag url_for(image), class: "w-full h-auto" %>
          <%= form_with url: remove_image_post_path(post, image_id: image.id), method: :delete, local: true, class: "absolute top-2 right-2" do %>
            <%= submit_tag "✕",
                data: { confirm: "Delete this image?" },
                class: "bg-white bg-opacity-75 rounded-full px-2 py-1 text-xs font-semibold text-red-600 hover:bg-opacity-100 transition" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
<%# === Main Post Edit Form === %>
<%= form_with(model: post, class: "space-y-6") do |form| %>
  <% if post.errors.any? %>
    <div class="bg-red-50 p-4 rounded-md mb-6">
      <div class="font-medium text-red-800">
        <%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:
      </div>
      <ul class="mt-3 list-disc list-inside text-sm text-red-600">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div>
    <%= form.label :sub_title, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :sub_title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :description, rows: 5, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div>
    <%= form.label :client, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :client, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div>
    <%= form.label :release_year, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :release_year, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div>
    <%= form.label :images, "Upload Images" %>
    <%= form.file_field :images, multiple: true, direct_upload: true %>
  </div>
  <div>
    <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
    <%= form.select :status,
                    options_for_select([['Draft', 'draft'], ['Published', 'published']], post.status),
                    { include_blank: "Select a status" },
                    class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div class="flex items-start">
    <div class="flex items-center h-5">
      <%= form.check_box :private_post, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
    </div>
    <div class="ml-3 text-sm">
      <%= form.label :private_post, "Private Post", class: "font-medium text-gray-700" %>
      <p class="text-gray-500">Check if this post should be private</p>
    </div>
  </div>
  <div>
    <%= form.label :display_order, class: "block text-sm font-medium text-gray-700" %>
    <%= form.number_field :display_order, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div class="flex gap-3">
    <%= form.submit class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
    <%= link_to "Cancel", posts_path, class: "inline-flex justify-center rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  </div>
<% end %>
